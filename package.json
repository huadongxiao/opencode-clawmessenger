{
  "name": "@neomei/opencode-clawmessenger",
  "version": "0.3.0",
  "description": "OpenCode ClawMessenger Bridge - 融云虾说桥接插件",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opencode-clawmessenger": "bin/opencode-clawmessenger",
    "opencode-clawmessenger-setup": "bin/opencode-clawmessenger-setup"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "start:win": "chcp 65001 >nul & node dist/cli.js start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "clawmessenger",
    "rongcloud",
    "im",
    "bridge"
  ],
  "author": "neomei",
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "^1.0.0",
    "@rongcloud/imlib-next": "5.36.6",
    "axios": "^1.15.0",
    "commander": "^12.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "ws": "^8.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}